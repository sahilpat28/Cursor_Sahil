BT /F3 8 Tf 54 554.00 Td (  echo "---- mgbe${i}_0 ----") Tj ET
BT /F3 8 Tf 54 544.00 Td (  sudo ethtool mgbe${i}_0 | grep -E "Speed|Link detected") Tj ET
BT /F3 8 Tf 54 534.00 Td (done) Tj ET
