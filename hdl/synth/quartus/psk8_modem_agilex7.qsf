# Quartus Prime Pro project assignments for standalone 8-PSK modem timing.
#
# IMPORTANT:
#   The top-level entity is psk8_modem_quartus_top, not psk8_modem_top.
#   psk8_modem_top is the reusable modem core and exposes the full packed
#   DAC/ADC buses. Compiling that raw core as the project top creates 1094
#   package I/O pins and will fail on the Agilex 7 development kit device.

set_global_assignment -name FAMILY "Agilex 7"
set_global_assignment -name DEVICE AGIB027R31B1E1VC
set_global_assignment -name TOP_LEVEL_ENTITY psk8_modem_quartus_top
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files

set_global_assignment -name VERILOG_FILE ../../rtl/psk8_mapper.v
set_global_assignment -name VERILOG_FILE ../../rtl/psk8_demapper.v
set_global_assignment -name VERILOG_FILE ../../rtl/srrc_fir_8x.v
set_global_assignment -name VERILOG_FILE ../../rtl/nco_rotator_8x.v
set_global_assignment -name VERILOG_FILE ../../rtl/psk8_tx.v
set_global_assignment -name VERILOG_FILE ../../rtl/psk8_rx.v
set_global_assignment -name VERILOG_FILE ../../rtl/psk8_modem_top.v
set_global_assignment -name VERILOG_FILE ../../rtl/psk8_modem_quartus_top.v
set_global_assignment -name SDC_FILE psk8_modem_500mhz.sdc

set_global_assignment -name OPTIMIZATION_MODE "AGGRESSIVE PERFORMANCE"
set_global_assignment -name AUTO_DSP_RECOGNITION ON
set_global_assignment -name PHYSICAL_SYNTHESIS_COMBO_LOGIC ON
set_global_assignment -name PHYSICAL_SYNTHESIS_REGISTER_DUPLICATION ON
set_global_assignment -name PHYSICAL_SYNTHESIS_REGISTER_RETIMING ON

# Standalone core timing build: keep all wrapper ports virtual so Quartus does
# not require package pin locations or board I/O standards. Remove/replace these
# assignments in the final board-level project when connecting real pins/IP.
set_instance_assignment -name VIRTUAL_PIN ON -to clk
set_instance_assignment -name VIRTUAL_PIN ON -to rst
set_instance_assignment -name VIRTUAL_PIN ON -to block_valid
set_instance_assignment -name VIRTUAL_PIN ON -to seed_load
set_instance_assignment -name VIRTUAL_PIN ON -to "prbs_seed[*]"
set_instance_assignment -name VIRTUAL_PIN ON -to "rx_phase_inc[*]"
set_instance_assignment -name VIRTUAL_PIN ON -to rx_phase_clear
set_instance_assignment -name VIRTUAL_PIN ON -to "tx_bits[*]"
set_instance_assignment -name VIRTUAL_PIN ON -to "tx_symbol_valid[*]"
set_instance_assignment -name VIRTUAL_PIN ON -to "rx_bits[*]"
set_instance_assignment -name VIRTUAL_PIN ON -to "rx_bits_valid[*]"

